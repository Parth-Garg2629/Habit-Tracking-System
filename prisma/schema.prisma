generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  level         Int             @default(1)
  xp            Int             @default(0)
  timezone      String          @default("UTC")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  habits        Habit[]
  skills        Skill[]
  dailyLogs     DailyLog[]
  quests           Quest[]
  xpEvents         XpEvent[]
  questCompletions QuestCompletion[]
  levelHistory     LevelHistory[]
  aiAnalyses       AiAnalysis[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Habit {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String?
  cadence     HabitCadence @default(DAILY)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     HabitEntry[]
}

model HabitEntry {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Skill {
  id          String        @id @default(cuid())
  userId      String
  name        String
  category    String?
  description String?
  level       Int           @default(1)
  xp          Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        LearningLog[]
  quests      Quest[]
}

model LearningLog {
  id        String   @id @default(cuid())
  skillId   String
  date      DateTime @default(now())
  title     String
  summary   String
  source    String?
  minutes   Int?
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  mood      String?
  wins      String?
  learned   String?
  blockers  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Quest {
  id          String            @id @default(cuid())
  userId      String
  skillId     String?
  title       String
  description String?
  status      QuestStatus       @default(TODO)
  dueDate     DateTime?
  xpReward    Int               @default(10)
  isDaily     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill       Skill?            @relation(fields: [skillId], references: [id], onDelete: SetNull)
  completions QuestCompletion[]
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestCompletion {
  id             String   @id @default(cuid())
  questId        String
  userId         String
  completionDate DateTime @db.Date
  completedAt    DateTime @default(now())
  xpAwarded      Int
  quest          Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questId, userId, completionDate])
  @@index([userId, completionDate])
  @@index([userId, completedAt])
}

model LevelHistory {
  id        String   @id @default(cuid())
  userId    String
  fromLevel Int
  toLevel   Int
  totalXp   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum HabitCadence {
  DAILY
  WEEKLY
  CUSTOM
}

enum QuestStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

model AiAnalysis {
  id             String   @id @default(cuid())
  userId         String
  logContent     String
  detectedSkills Json
  totalXpSuggested Int
  summary        String
  status         AnalysisStatus @default(PENDING)
  confirmedAt    DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum AnalysisStatus {
  PENDING
  CONFIRMED
  REJECTED
}
